# Copy this file to .env.local and fill in the values from your Supabase project.
# In Supabase dashboard: Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only needed if you want server-side admin actions that bypass RLS.
# Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set to an ISO datetime (UTC) to lock entries at that moment.
NEXT_PUBLIC_LOCK_DATE=2026-04-19T19:00:00Z
